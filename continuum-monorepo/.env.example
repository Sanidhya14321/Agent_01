# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...              # GPT-4o (primary synthesiser)
OPENAI_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/continuum
DIRECT_URL=postgresql://postgres:password@localhost:5432/continuum

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Auth (NextAuth.js) ────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── OAuth Integrations ────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=                  # Gmail + YouTube (same Google App)
GOOGLE_CLIENT_SECRET=

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Agent Hub ────────────────────────────────────────────────────────────────
AGENT_HUB_URL=http://localhost:8000
AGENT_MAX_ITERATIONS=5
AGENT_CONFIDENCE_THRESHOLD=0.7

# ── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=continuum-agent-hub
